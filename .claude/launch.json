{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "hub",
      "runtimeExecutable": ".venv/bin/python",
      "runtimeArgs": ["-m", "uvicorn", "hub.app:app", "--port", "8099"],
      "env": { "VERITAS_DATA": "./hub_data" },
      "port": 8099
    },
    {
      "name": "docs",
      "runtimeExecutable": "python3",
      "runtimeArgs": ["-m", "http.server", "8077", "--directory", "docs"],
      "port": 8077
    }
  ]
}
